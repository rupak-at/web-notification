# =========================

# Node.js Backend .gitignore

# =========================

# 📦 Dependencies

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 🔐 Environment variables

.env
.env.*
!.env.example

# 🗄️ Database

*.sqlite3
*.db
*.db-journal

# 🧾 Logs

logs/
*.log

# 📁 Build / Output

dist/
build/
out/

# 🧪 Coverage

coverage/

# ⚙️ OS / System files

.DS_Store
Thumbs.db

# 🧠 IDE / Editor

.vscode/
.idea/
*.swp
*.swo

# 🔄 Temporary files

tmp/
temp/

# 📦 Cache

.cache/
.parcel-cache/

# 🐳 Docker (optional)

docker-compose.override.yml

# 🔑 Keys / Certificates

*.pem
*.key
*.crt

# 📤 Uploads (if your app stores files)

uploads/
public/uploads/

# 🧩 Knex (optional but useful)

# Uncomment if you don’t want migrations in git

# migrations/

# seeds/

# 🚀 PM2

.pm2/
 